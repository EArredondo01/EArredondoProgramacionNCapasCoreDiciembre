@model ML.Materia
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


<div class="container">
    <div class="row">
        <div class="col-12">
            <h1>Materia</h1>
        </div>
    </div>

    @using (Html.BeginForm("Formulario", "Materia", FormMethod.Post))
    {
        <div class="row">
            <div class="col-12">
                <div class="mb-3">
                    @Html.LabelFor(model => model.Nombre)
                    @Html.TextBoxFor(model => model.Nombre)
                </div>

                <div class="mb-3">
                    @Html.LabelFor(model => model.Promedio)
                    @Html.TextBoxFor(model => model.Promedio)
                </div>


                @* Demas informacion ....*@
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <h1>Grupos</h1>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="mb-3">
                    @Html.LabelFor(model => model.Grupo.Nombre)
                    @Html.TextBoxFor(model => model.Nombre)
                </div>

                <div class="mb-3">
                    @Html.LabelFor(model => model.Grupo.Plantel.IdPlantel)
                    @Html.TextBoxFor(model => model.Grupo.Plantel.IdPlantel)
                </div>
            </div>
        </div>

    }



</div>

